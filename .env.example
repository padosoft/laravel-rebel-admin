# ============================================================================
# laravel-rebel-admin — environment variables
# ============================================================================

# Where the web panel is mounted.
REBEL_ADMIN_PREFIX=admin/rebel

# Auth guard the panel requires ('' = app default).
REBEL_ADMIN_GUARD=

# Gate ability required to view the panel. Fail-closed by default — define this Gate.
REBEL_ADMIN_ABILITY=rebel-admin

# Base URL the panel's JS calls for data (the Rebel Admin API prefix).
REBEL_ADMIN_API_BASE=/rebel/admin/api/v1

# Where unauthenticated visitors are redirected.
REBEL_ADMIN_LOGIN_REDIRECT=/login
